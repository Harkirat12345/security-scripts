failed_logins = 0
ip_counts = {}
username_counts = {}

with open("auth.log", "r") as file:
    for line in file:
        if "Failed" in line:
            failed_logins += 1

            words = line.split()
            username = words[3]
            ip_address = words[5]

            if ip_address in ip_counts:
                ip_counts[ip_address] += 1
            else:
                ip_counts[ip_address] = 1

            if username in username_counts:
                username_counts[username] += 1
            else:
                username_counts[username] = 1

print("===== Failed Login Report =====")
print(f"Number of failed logins: {failed_logins}")

print("\nFailed logins by IP:")
for ip in ip_counts:
    print(f"{ip}: {ip_counts[ip]}")

print("\nRepeated usernames:")
for username in username_counts:
    print(f"{username}: {username_counts[username]}")
